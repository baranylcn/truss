# Auth provider: "local" (no Supabase needed) or "supabase"
AUTH_PROVIDER=local

# Storage provider: "local" (filesystem) or "supabase"
STORAGE_PROVIDER=local

# Local auth settings (only used when AUTH_PROVIDER=local)
LOCAL_JWT_SECRET=dev-secret-change-in-production
LOCAL_JWT_EXPIRE_DAYS=7
LOCAL_STORAGE_PATH=./data/uploads

# Database (PostgreSQL with asyncpg driver)
# For local dev: spin up with `docker compose up postgres` or use an existing instance
DATABASE_URL=postgresql+asyncpg://truss:truss_dev@localhost:5432/truss

# Redis (optional - caching is skipped if unset)
REDIS_URL=redis://localhost:6379

# Per-user / upload limits (applied equally to every user; override in your own .env)
MAX_UPLOAD_MB=25
MAX_PROJECTS_PER_USER=10

# CORS
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase (only required when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=your-storage-bucket-name
