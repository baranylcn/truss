# Auth provider: "local" (no external services) or "supabase" (production)
# Defaults to "local" when not set - contributors need nothing extra.
VITE_AUTH_PROVIDER=local

# Backend API URL (defaults to http://localhost:8000/api when not set)
VITE_API_BASE_URL=http://localhost:8000/api

# Supabase (only required when VITE_AUTH_PROVIDER=supabase)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
